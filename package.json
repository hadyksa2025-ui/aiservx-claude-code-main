{
  "name": "claude-code-main-snapshot",
  "version": "0.0.0-snapshot",
  "private": true,
  "description": "Recovered build scaffold for a Claude Code source snapshot.",
  "type": "module",
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.1.0",
  "bin": {
    "claude-snapshot": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run ./src/entrypoints/cli.tsx",
    "build": "bun run ./scripts/build.ts",
    "build:exe": "bun run ./scripts/build-exe.ts",
    "typecheck": "tsc --noEmit",
    "snapshot": "powershell -ExecutionPolicy Bypass -File ./scripts/run-snapshot.ps1",
    "snapshot:help": "powershell -ExecutionPolicy Bypass -File ./scripts/run-snapshot.ps1 --help",
    "snapshot:auth": "powershell -ExecutionPolicy Bypass -File ./scripts/run-snapshot.ps1 auth status",
    "snapshot:print": "powershell -ExecutionPolicy Bypass -File ./scripts/run-snapshot.ps1 -p \"hello\" --bare"
  },
